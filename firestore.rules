rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 사용자 본인의 통화 기록만 접근 가능
    match /users/{userId}/calls/{callId} {
      allow read, delete: if request.auth != null
                          && request.auth.uid == userId;

      // 생성은 본인만, 필수 필드 검증
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasAll(['createdAt', 'status', 'roomUrl', 'roomName']);

      // 업데이트는 본인만, status 값 제한
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.status in ['pending', 'completed', 'failed'];
    }

    // rooms 컬렉션: 클라이언트는 생성만 가능, 읽기/수정 불가
    // (읽기는 Cloud Function이 Admin SDK로 처리)
    match /rooms/{roomName} {
      allow create: if request.auth != null;
      allow read, update, delete: if false; // Admin SDK만 허용
    }
  }
}

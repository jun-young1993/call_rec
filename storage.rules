rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 녹음 파일: 본인 파일만 읽기 가능, 쓰기는 Cloud Function(Admin SDK)만
    match /recordings/{userId}/{callId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // Cloud Function Admin SDK만 허용
    }
  }
}
